DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=blackcard.joinhavn.io,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://blackcard.joinhavn.io
CSRF_TRUSTED_ORIGINS=https://blackcard.joinhavn.io
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
FORCE_HTTPS=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
# Required on Vercel. Use a persistent Postgres database.
DATABASE_URL=postgresql://username:password@pooled-hostname:5432/black_trivia?sslmode=require&channel_binding=require
# Optional but recommended for build-time migrations on Neon.
DATABASE_URL_UNPOOLED=postgresql://username:password@direct-hostname:5432/black_trivia?sslmode=require&channel_binding=require
# Alternative to DATABASE_URL on Vercel/Neon.
PGHOST=pooled-hostname
PGHOST_UNPOOLED=direct-hostname
PGPORT=5432
PGDATABASE=black_trivia
PGUSER=username
PGPASSWORD=password
PGSSLMODE=require
PGCHANNELBINDING=require
